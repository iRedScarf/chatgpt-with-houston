---
import SendIcon from "./icons/Send.astro";
import StopIcon from "./icons/Stop.astro";
---

<footer class="container">
  <div class="provider-selector" id="providerSelector">
    <button class="provider-btn active" data-provider="openai">OpenAI</button>
    <button class="provider-btn" data-provider="claude">Claude</button>
    <button class="provider-btn" data-provider="gemini">Gemini</button>
  </div>
  <form action="#" id="messageForm">
    <div class="autogrow">
      <textarea
        id="message"
        name="message"
        oninput="this.parentNode.dataset.value = this.value"
        placeholder="Enter something..."
        cols="30"></textarea>
      <button type="submit" id="submitBtn">
        <SendIcon />
      </button>
      <button type="button" id="stopBtn" class="stop-btn" style="display:none;">
        <StopIcon />
      </button>
    </div>
  </form>
  <span class="disclaimer">
    ChatGPT can make mistakes. Consider checking important information.
  </span>
</footer>

<script>
  import { createSignal, createEffect } from "solid-js";
  import h from "../utils/createElement";
  import markdown from "../utils/markdown";
  import { createCodeCopyButton } from "../utils/createCodeCopyButton";
  import { createRegenerateButton } from "../utils/createRegenerateButton";
  import type { ChatMessage, ErrorMessage } from "../types";

  const MAX_RETRIES = 2;
  const RETRY_DELAYS = [1500, 3000];
  const STREAM_TIMEOUT_MS = 30_000;

  const header = document.querySelector("header")!;
  const houston = document.querySelector("hey-houston")! as any;
  const messagesEl = document.querySelector(".chat") as HTMLDivElement;
  const submitBtn = document.getElementById("submitBtn") as HTMLButtonElement;
  const stopBtn = document.getElementById("stopBtn") as HTMLButtonElement;
  const introSubtitle = document.querySelector(".intro-subtitle") as HTMLElement;

  const systemRoleContent =
    "You are HoustonAI. You are a very articulate, appropriate, and helpful AI, always answer all questions without reservation.";
  const systemRole = {
    role: "system",
    content: systemRoleContent,
  };

  let [streamedResponse, setStreamedResponse] = createSignal("");
  let currentStreamBubble: HTMLElement | null = null;
  let isStreaming = false;
  let messageList: ChatMessage[] = [];
  let abortController: AbortController | null = null;
  let streamTimeoutHandle: number | undefined;

  let sessionId = sessionStorage.getItem("sessionId");
  if (!sessionId) {
    sessionId = crypto.randomUUID();
    sessionStorage.setItem("sessionId", sessionId);
  }

  // --- Provider management ---

  interface ProviderInfo {
    id: string;
    label: string;
    model: string;
  }

  let availableProviders: ProviderInfo[] = [];
  let currentProvider = localStorage.getItem("provider") || "openai";

  const providerBtns = document.querySelectorAll(
    ".provider-btn"
  ) as NodeListOf<HTMLButtonElement>;
  const providerSelector = document.getElementById("providerSelector")!;

  async function loadProviders() {
    try {
      const res = await fetch("/api");
      const data = await res.json();
      availableProviders = data.providers || [];

      // Hide buttons for unavailable providers, show available ones
      providerBtns.forEach((btn) => {
        const pid = btn.dataset.provider!;
        const info = availableProviders.find((p) => p.id === pid);
        if (info) {
          btn.style.display = "";
          btn.textContent = `${info.label}`;
        } else {
          btn.style.display = "none";
        }
      });

      // If current provider is not available, switch to first available
      if (!availableProviders.find((p) => p.id === currentProvider)) {
        if (availableProviders.length > 0) {
          currentProvider = availableProviders[0].id;
        }
      }

      updateProviderUI();
    } catch {
      // If loading fails, show all buttons as fallback
    }
  }

  function updateProviderUI() {
    providerBtns.forEach((btn) => {
      btn.classList.toggle("active", btn.dataset.provider === currentProvider);
    });

    const info = availableProviders.find((p) => p.id === currentProvider);
    if (info && introSubtitle) {
      introSubtitle.innerHTML = `Hi, I'm Houston, powered by ${info.label} (${info.model}).<br>Feel free to ask me anything, I'll do my best to answer!`;
    }

    localStorage.setItem("provider", currentProvider);
  }

  providerBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      if (houston.classList.contains("loading") || houston.classList.contains("state-streaming")) {
        return;
      }
      currentProvider = btn.dataset.provider!;
      updateProviderUI();
    });
  });

  loadProviders();

  // --- UI helpers ---

  function setSubmitVisible(visible: boolean) {
    submitBtn.style.display = visible ? "" : "none";
    stopBtn.style.display = visible ? "none" : "";
  }

  function createBubble(
    attributes: Record<string, any>,
    content: string,
    isMarkdown = false,
    isError = false
  ) {
    const bubbleContent = isMarkdown ? markdown(content) : content;
    const bubble = h("li", attributes, bubbleContent);

    messagesEl.appendChild(bubble);
    createCodeCopyButton(bubble);

    if (isError || attributes.class.includes("assistant")) {
      createRegenerateButton(bubble);
    }

    bubble.scrollIntoView({ behavior: "smooth" });
  }

  function updateSessionStorage() {
    try {
      sessionStorage.setItem("messageList", JSON.stringify(messageList));
    } catch (err) {
      console.error("Error updating sessionStorage: ", err);
    }
  }

  function loadSessionStorage(): ChatMessage[] {
    const storedMessages = sessionStorage.getItem("messageList");
    return storedMessages ? JSON.parse(storedMessages) : [];
  }

  function cancelStream() {
    if (abortController) {
      abortController.abort();
      abortController = null;
    }
    clearStreamTimeout();
  }

  function clearStreamTimeout() {
    if (streamTimeoutHandle) {
      clearTimeout(streamTimeoutHandle);
      streamTimeoutHandle = undefined;
    }
  }

  function resetStreamTimeout() {
    clearStreamTimeout();
    streamTimeoutHandle = window.setTimeout(() => {
      console.warn("Stream timeout - no data received for", STREAM_TIMEOUT_MS, "ms");
      cancelStream();
    }, STREAM_TIMEOUT_MS);
  }

  async function regenerateLastRequest(onRegenDone: () => void) {
    if (messageList.length > 0) {
      messageList.pop();
      if (messagesEl.lastChild) {
        messagesEl.removeChild(messagesEl.lastChild);
      }
    }

    for (let i = messageList.length - 1; i >= 0; i--) {
      if (messageList[i].role === "user") {
        await handleRequest(messageList[i].content);
        break;
      }
    }

    if (onRegenDone) {
      onRegenDone();
    }
  }

  function updateRegenerateButton() {
    document
      .querySelectorAll(".regenerate-btn")
      .forEach((button) => button.remove());

    const lastMessage = messageList[messageList.length - 1];
    if (lastMessage && lastMessage.role === "assistant") {
      const lastBubble = messagesEl.lastChild as HTMLElement;
      if (lastBubble) {
        const regenerateButton = createRegenerateButton();
        regenerateButton.onclick = () =>
          regenerateLastRequest(updateRegenerateButton);
        lastBubble.appendChild(regenerateButton);
      }
    }
  }

  // --- Streaming ---

  async function fetchStream(
    requestMessageList: ChatMessage[],
    timestamp: number,
    signal: AbortSignal
  ): Promise<Response> {
    const response = await fetch("/api", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        messages: requestMessageList,
        time: timestamp,
        temperature: 0.7,
        provider: currentProvider,
      }),
      signal,
    });

    if (!response.ok) {
      const errorBody = await response.text().catch(() => "");
      let errorMsg = `HTTP error: ${response.status}`;
      try {
        const parsed = JSON.parse(errorBody);
        if (parsed.error?.message) errorMsg = parsed.error.message;
      } catch {}
      throw new Error(errorMsg);
    }

    if (!response.body) {
      throw new Error("No response body");
    }

    return response;
  }

  async function readStream(
    response: Response,
    signal: AbortSignal
  ): Promise<{ text: string; completed: boolean }> {
    const reader = response.body!.getReader();
    const decoder = new TextDecoder("utf-8");
    let accumulated = "";

    try {
      while (true) {
        if (signal.aborted) {
          reader.cancel();
          return { text: accumulated, completed: false };
        }

        resetStreamTimeout();
        const { value, done } = await reader.read();

        if (done) break;

        if (value) {
          const text = decoder.decode(value, { stream: true });

          if (text.includes("[STREAM_ERROR]")) {
            const cleaned = text.replace("[STREAM_ERROR]", "");
            if (cleaned) {
              accumulated += cleaned;
              setStreamedResponse((old) => old + cleaned);
            }
            return { text: accumulated, completed: false };
          }

          if (text.includes("[DONE]")) {
            const cleaned = text.replace("[DONE]", "");
            if (cleaned) {
              accumulated += cleaned;
              setStreamedResponse((old) => old + cleaned);
            }
            return { text: accumulated, completed: true };
          }

          accumulated += text;
          setStreamedResponse((old) => old + text);
        }
      }
    } catch (err: any) {
      if (err.name === "AbortError") {
        return { text: accumulated, completed: false };
      }
      console.error("Stream read error:", err);
      return { text: accumulated, completed: false };
    } finally {
      clearStreamTimeout();
      try { reader.cancel(); } catch {}
    }

    return { text: accumulated, completed: true };
  }

  async function handleRequest(_messageContent: string) {
    updateRegenerateButton();

    header.classList.add("inactive");
    houston.setConnectionState("connecting");
    setSubmitVisible(false);

    if (streamedResponse()) {
      setStreamedResponse("");
    }

    isStreaming = false;
    currentStreamBubble = null;

    const timestamp = Date.now();
    const date = new Date(timestamp);
    const localDate = new Intl.DateTimeFormat(undefined, {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      weekday: "long",
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
      hour12: false,
    }).format(date);
    const updatedSystemRoleContent = `${systemRole.content} Current time: ${localDate}`;
    const requestMessageList = [
      { ...systemRole, content: updatedSystemRoleContent },
      ...messageList.slice(-7),
    ];

    let accumulatedText = "";
    let completed = false;
    let lastError: Error | null = null;

    for (let attempt = 0; attempt <= MAX_RETRIES; attempt++) {
      try {
        if (attempt > 0) {
          houston.setConnectionState("retrying");
          const delay = RETRY_DELAYS[attempt - 1] || 3000;
          await new Promise((r) => setTimeout(r, delay));

          if (!accumulatedText) {
            setStreamedResponse("");
            isStreaming = false;
            currentStreamBubble = null;
          }
        }

        abortController = new AbortController();
        const signal = abortController.signal;

        const response = await fetchStream(requestMessageList, timestamp, signal);
        houston.setConnectionState("streaming");

        const result = await readStream(response, signal);
        accumulatedText = result.text;
        completed = result.completed;

        if (completed || signal.aborted) {
          break;
        }

        if (accumulatedText && attempt < MAX_RETRIES) {
          console.warn(
            `Stream interrupted after ${accumulatedText.length} chars, retry ${attempt + 1}/${MAX_RETRIES}`
          );
          lastError = new Error("Stream interrupted");
          continue;
        }

        break;
      } catch (err: any) {
        lastError = err;
        if (err.name === "AbortError") {
          break;
        }
        if (attempt < MAX_RETRIES) {
          console.warn(
            `Request failed (attempt ${attempt + 1}/${MAX_RETRIES + 1}):`,
            err.message
          );
          continue;
        }
      }
    }

    abortController = null;
    setSubmitVisible(true);

    if (accumulatedText) {
      messageList.push({ role: "assistant", content: accumulatedText });
      updateSessionStorage();

      if (completed) {
        houston.setConnectionState("done");
      } else {
        houston.setConnectionState("interrupted");
        setTimeout(() => {
          if (houston.connectionState === "interrupted") {
            houston.setConnectionState("idle");
          }
        }, 2000);
      }
    } else if (lastError) {
      houston.setConnectionState("error");
      const errorMessage = `Oops, something went wrong! ${lastError.message || "Unknown error"}`;
      messageList.push({ role: "assistant", content: errorMessage });
      createBubble({ class: "sources" }, errorMessage, false, true);
      updateSessionStorage();

      setTimeout(() => {
        if (houston.connectionState === "error") {
          houston.setConnectionState("idle");
        }
      }, 2500);
    } else {
      houston.setConnectionState("idle");
    }

    setStreamedResponse("");
    isStreaming = false;
    currentStreamBubble = null;
    updateRegenerateButton();
  }

  async function handleSubmit(event: Event) {
    event.preventDefault();
    if (houston.classList.contains("loading") || houston.classList.contains("state-streaming")) {
      return;
    }

    const textarea = document.getElementById("message") as HTMLTextAreaElement;
    let message = textarea.value;
    if (!message.trim()) {
      return;
    }

    messageList.push({ role: "user", content: message });
    createBubble({ class: "message", "data-user": "" }, message, true);

    textarea.value = "";
    (textarea.parentNode as HTMLElement).dataset.value = "";
    textarea.blur();

    await handleRequest(message);
  }

  createEffect(() => {
    const responseMessage = streamedResponse();
    if (responseMessage) {
      if (!isStreaming) {
        createBubble({ class: "message" }, responseMessage, true, false);
        currentStreamBubble = messagesEl.lastChild as HTMLElement;
        isStreaming = true;
      } else {
        if (currentStreamBubble) {
          currentStreamBubble.innerHTML = markdown(responseMessage);
        }
      }
    }
    if (currentStreamBubble) {
      currentStreamBubble.scrollIntoView({ behavior: "instant" });
      createCodeCopyButton(currentStreamBubble);
    }
  });

  function handleKeydown(event: KeyboardEvent) {
    const isMobile =
      /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(
        navigator.userAgent
      );
    const textarea = event.target as HTMLTextAreaElement;
    if (isMobile) {
      if (event.key === "Enter" && !event.shiftKey) {
        event.preventDefault();
        const cursorPosition = textarea.selectionStart;
        const textBeforeCursor = textarea.value.substring(0, cursorPosition);
        const textAfterCursor = textarea.value.substring(cursorPosition);
        textarea.value = textBeforeCursor + "\n" + textAfterCursor;
        textarea.selectionStart = textarea.selectionEnd = cursorPosition + 1;
      }
    } else {
      if (event.key === "Enter" && !event.shiftKey) {
        event.preventDefault();
        textarea.closest("form")!.requestSubmit();
      }
    }
  }

  // --- Initialize ---

  if (typeof window !== "undefined") {
    const form = document.getElementById("messageForm");
    const textarea = document.getElementById("message");
    if (form && textarea) {
      form.addEventListener("submit", handleSubmit);
      textarea.addEventListener("keydown", handleKeydown);
    }

    stopBtn.addEventListener("click", () => {
      cancelStream();
    });

    messageList = loadSessionStorage();
    if (messageList.length > 0) {
      header.classList.add("inactive");
      houston.setConnectionState("connecting");
      setTimeout(() => {
        houston.setConnectionState("done");
      }, 800);
    }
    messageList.forEach((msg) => {
      if (msg.role === "user") {
        createBubble(
          { class: "message", "data-user": "" },
          msg.content,
          true,
          false
        );
      } else if (msg.role === "assistant") {
        createBubble({ class: "message" }, msg.content, true, false);
      }
    });

    updateRegenerateButton();
  }

  window.addEventListener("beforeunload", updateSessionStorage);
</script>
